{
  "id": null,
  "uid": "idps-overview",
  "title": "IDPS Overview",
  "tags": ["idps"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Active Blocked IPs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "idps_blocked_ips_active",
          "legendFormat": "Blocked IPs",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Events (last hour)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "idps_events_recent_1h",
          "legendFormat": "Events/hour",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total Events Ingested",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "targets": [
        {
          "expr": "idps_events_total",
          "legendFormat": "Total events",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Alerts by Severity",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right" }
      },
      "targets": [
        {
          "expr": "idps_alerts_total{severity=\"critical\"}",
          "legendFormat": "Critical",
          "refId": "A"
        },
        {
          "expr": "idps_alerts_total{severity=\"high\"}",
          "legendFormat": "High",
          "refId": "B"
        },
        {
          "expr": "idps_alerts_total{severity=\"medium\"}",
          "legendFormat": "Medium",
          "refId": "C"
        },
        {
          "expr": "idps_alerts_total{severity=\"low\"}",
          "legendFormat": "Low",
          "refId": "D"
        }
      ]
    },
    {
      "id": 5,
      "title": "Events per Hour (trend)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "idps_events_recent_1h",
          "legendFormat": "Events/hour",
          "refId": "A"
        },
        {
          "expr": "idps_blocked_ips_active",
          "legendFormat": "Active blocks",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "Pi Node — CPU Usage %",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{instance=\"10.10.0.2:9100\",mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "Pi CPU %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Pi Node — Memory Usage %",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{instance=\"10.10.0.2:9100\"} / node_memory_MemTotal_bytes{instance=\"10.10.0.2:9100\"}) * 100",
          "legendFormat": "Pi Memory %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "MongoDB — Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "mongodb_connections{state=\"current\"}",
          "legendFormat": "Active connections",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "MongoDB — Operations/sec",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(mongodb_op_counters_total[1m])",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    }
  ]
}
